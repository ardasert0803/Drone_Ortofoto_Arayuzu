# Cesium ion erişim token'i (https://cesium.com/ion/tokens)
# DİKKAT: '=' işareti şart. Token örneği:
#   CESIUM_ION_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
CESIUM_ION_TOKEN=your_cesium_ion_token_here

# NodeODM (Docker container) bağlantısı
NODEODM_HOST=localhost
NODEODM_PORT=3000

# FastAPI ayarları
APP_HOST=0.0.0.0
APP_PORT=8000

# Veri klasörleri (göreli yol — proje köküne göre)
UPLOAD_DIR=./data/uploads
OUTPUT_DIR=./data/outputs
TILES_DIR=./data/tiles
